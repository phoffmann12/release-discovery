# Copy to .env and fill in. All four of the first block are required.

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
LASTFM_API_KEY=
NTFY_TOPIC=metal-releases-CHANGE-ME-to-something-unguessable

# --- optional, sane defaults shown ---
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback   # must match your Spotify app
# NTFY_URL=https://ntfy.sh                               # or your self-hosted ntfy
# SCAN_INTERVAL_HOURS=6         # how often to scan Metal Archives
# TASTE_TTL_HOURS=24            # how often to re-pull Spotify + Last.fm
# NOTIFY_LEAD_DAYS=7            # window upper bound: notify at most this many days pre-release
# MA_LOOKBACK_DAYS=0            # window lower bound: 0 = today onward; raise for a downtime safety margin
# SIMILAR_SCORE_MIN=0.6         # discovery: min Last.fm match to qualify alone
# SIMILAR_CONSENSUS=2           # discovery: qualify if similar to >= N taste artists
# SIMILAR_LIMIT=50              # similar artists fetched per taste artist
