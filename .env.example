# Copy to .env and fill in. All four of the first block are required.

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
LASTFM_API_KEY=
NTFY_TOPIC=metal-releases-CHANGE-ME-to-something-unguessable

# --- optional, sane defaults shown ---
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback   # must match your Spotify app
# NTFY_URL=https://ntfy.sh                               # or your self-hosted ntfy
# SCAN_INTERVAL_HOURS=6         # how often to scan Metal Archives
# TASTE_TTL_HOURS=24            # how often to re-pull Spotify + Last.fm
# NOTIFY_LEAD_DAYS=7            # window upper bound: notify at most this many days pre-release
# MA_LOOKBACK_DAYS=0            # window lower bound: 0 = today onward; raise for a downtime safety margin
# SIMILAR_SCORE_MIN=0.6         # discovery: min Last.fm match to qualify on strength alone
# SIMILAR_CONSENSUS=2           # discovery: qualify if similar to >= N taste artists...
# SIMILAR_CONSENSUS_SCORE_MIN=0.3  # ...but only if max match also clears this floor (0 = old score-free consensus)
# SIMILAR_LIMIT=50              # similar artists fetched per taste artist

# --- concerts (ADR-0008, opt-in) ---
# Notify about concerts of your bands + similar bands, from Eventim. Leave
# CONCERT_CITIES empty to disable the whole feature (default). "Near me" is a list
# of cities, not a radius (Eventim's geo filter is city-based) — list your city and
# the neighbours you'd travel to, German spellings, comma-separated.
# CONCERT_CITIES=Bochum,Dortmund,Essen,Oberhausen,Köln
# CONCERT_LOOKAHEAD_DAYS=180    # how far ahead to look for shows
# CONCERT_MAX_PAGES=120         # safety cap on date-cursor requests per scan
# EVENTIM_WEB_ID=web__eventim-de   # Eventim storefront (…-de/-at/-ch); language pairs with it
# EVENTIM_LANGUAGE=de
# EVENTIM_CATEGORY=Konzerte     # top-level category filter (only the parent value works)
